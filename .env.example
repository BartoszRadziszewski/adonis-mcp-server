# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

#--------------------------------------------------------------------
# MCP Tools – workspace root used by generate_bpmn and other tools
# Set to the absolute path of your project folder
#--------------------------------------------------------------------
MCP_WORKSPACE_ROOT=C:\projects\your-project